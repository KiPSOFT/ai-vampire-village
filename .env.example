# ─── Client (Vite) Environment Variables ───────────────────────────────────────
# Bu dosyayı kopyalayıp .env olarak kaydet, değerleri kendi sunucuna göre ayarla.
# Copy this file to .env and adjust the values for your server.

# WebSocket (Socket.io) sunucu adresi — sadece origin, path dahil etme.
# Örnek: VITE_WS_URL=https://oyun.example.com
VITE_WS_URL=http://localhost:3001

# Socket.io path — nginx üzerinden proxy ediyorsan /ws/socket.io yap.
# Localhost'ta default /socket.io bırakabilirsin.
# Örnek (nginx /ws → backend): VITE_WS_PATH=/ws/socket.io
VITE_WS_PATH=/socket.io

# REST API adresi (istatistik sayfası vb. için).
# Nginx ile /api prefix altında proxyliyorsan bunu kullan.
# Örnek: VITE_API_URL=https://oyun.example.com
VITE_API_URL=http://localhost:3001

